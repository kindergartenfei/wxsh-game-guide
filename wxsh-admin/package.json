{
  "name": "wxsh-admin",
  "version": "1.0.0",
  "description": "妄想山海宠物变异攻略 — 后端 API 与管理后台",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "admin:install": "cd admin && npm install",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm run build",
    "build": "npm run admin:build",
    "import:archive": "node scripts/import-archive.mjs --replace",
    "seed:test": "node scripts/seed-test.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mysql2": "^3.12.0"
  }
}
